# Weaviate (shared with remember-rest-service)
WEAVIATE_REST_URL=http://localhost:8080
WEAVIATE_GRPC_URL=http://localhost:50051
WEAVIATE_API_KEY=

# Firebase/Firestore (shared with remember-rest-service)
FIREBASE_PROJECT_ID=
FIREBASE_ADMIN_SERVICE_ACCOUNT_KEY=

# Embeddings (shared with remember-rest-service)
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_API_KEY=

# Anthropic (new — for Haiku cluster validation)
ANTHROPIC_API_KEY=

# REM Mode (required)
# scheduler: enumerate collections, create jobs, trigger workers
# worker: pick up a job by JOB_ID and execute
REM_MODE=scheduler

# Worker mode only
JOB_ID=

# GCP (scheduler mode only — for triggering worker Cloud Run Jobs)
GCP_PROJECT_ID=com-f5-parm
GCP_REGION=us-central1
WORKER_JOB_NAME=remember-rem-worker

# Optional
NODE_ENV=development
LOG_LEVEL=info
